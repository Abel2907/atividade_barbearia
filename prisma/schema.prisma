datasource db {
  provider = "postgresql"
  url = env("")
}
generator client {
  provider = "prisma-client-js"
}

model User {
  id_user: String @id @default(uuid())
  email String @unique
  nome String
  senha String
  telefone_user String
  birth_date DateTime
  schedules Schedule[]
  @@map("User")
}

model Schedule {
  id_schedule String @id @default(uuid())
  servico String
  barbeiro String
  data_hora DateTime
  userId String
  user User @relation(fields:[userId], references:[id_user])
  @@map("Schedule")
}