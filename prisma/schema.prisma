datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Cliente {
  id        String     @id @default(uuid())
  email     String     @unique
  nome      String
  senha     String
  cpf       String     @unique
  schedules Schedule[]

  @@map("clientes")
}

model Schedule {
  id_schedule String   @id @default(uuid())
  servico     String
  barbeiro    String
  data_hora   DateTime
  userId      String
  cliente     Cliente  @relation(fields: [userId], references: [id])

  @@map("schedules")
}