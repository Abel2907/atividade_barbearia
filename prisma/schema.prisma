datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Cliente {
  id        String     @id @default(uuid())
  email     String     @unique
  nome      String
  senha     String
  schedules Schedule[]

  @@map("clientes")
}

model Schedule {
  id String   @id @default(uuid())
  servico     String
  barbeiro    String
  dataHora   DateTime
  clienteId String   @map("cliente_id")
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  @@map("schedules")
}